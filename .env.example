# ─────────────────────────────────────────────
#  iNRISE — Environment Variables (template)
#  Copy to `.env` and fill in real values.
#  `.env` is gitignored.
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
NODE_ENV=development
PORT=5000
HOST=127.0.0.1
BASE_URL=http://localhost:5000

# ── Database (PostgreSQL) ────────────────────
# Local Postgres:  postgres://USER:PASS@localhost:5432/inrise
# Neon (cloud):    postgres://USER:PASS@ep-xxx.neon.tech/inrise?sslmode=require
DATABASE_URL=

# ── Session ──────────────────────────────────
# Generate: `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
SESSION_SECRET=
# Only set in production when using a custom domain
COOKIE_DOMAIN=

# ── Bootstrap Admin (required for first prod bootstrap) ─────────────
# In production, no default admin is auto-created unless ADMIN_BOOTSTRAP_PASSWORD is set.
# In development, a strong temporary password is generated and logged if this is unset.
ADMIN_BOOTSTRAP_EMAIL=admin@inrise.com
ADMIN_BOOTSTRAP_PASSWORD=

# ── OpenAI (required) ────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL_STANDARD=gpt-5.4-mini
OPENAI_MODEL_PREMIUM=gpt-5.2
OPENAI_TTS_MODEL=tts-1
OPENAI_STT_MODEL=whisper-1

# ── ElevenLabs (optional / legacy TTS) ───────
ELEVENLABS_API_KEY=

# ── OAuth — Google ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── OAuth — Kakao ────────────────────────────
KAKAO_CLIENT_ID=

# ── Payments — Toss ──────────────────────────
TOSS_PAYMENTS_CLIENT_KEY=
TOSS_PAYMENTS_SECRET_KEY=
# Exposed to the browser (Vite) — client key only, never the secret
VITE_TOSS_CLIENT_KEY=

# ── Payments — Stripe ────────────────────────
# Public key exposed to the browser (Vite)
VITE_STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Payments — PayPal ────────────────────────
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# ── Object Storage (Google Cloud Storage) ────
# Set both for GCS-backed audio/file storage. If unset, falls back to local ./uploads.
PRIVATE_OBJECT_DIR=
GOOGLE_APPLICATION_CREDENTIALS=

# ── Object Storage (S3-compatible: Cloudflare R2, Hetzner, Backblaze B2) ──
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PREFIX=
S3_FORCE_PATH_STYLE=false
